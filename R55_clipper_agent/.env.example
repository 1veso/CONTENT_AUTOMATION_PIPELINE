# ============================================================================
# R55 Clipper — Environment Variables
# ============================================================================
# These are stored as a Modal Secret called "vizard-clipper-secrets"
#
# To create the Modal Secret, run:
#   modal secret create vizard-clipper-secrets \
#     VIZARD_API_KEY=your_vizard_api_key \
#     TELEGRAM_BOT_TOKEN=your_telegram_bot_token \
#     AIRTABLE_PAT=your_airtable_personal_access_token \
#     AIRTABLE_BASE_ID=your_airtable_base_id \
#     AIRTABLE_TABLE_NAME=shortsRobo \
#     BLOTATO_API_KEY=your_blotato_api_key \
#     BLOTATO_YOUTUBE_ACCOUNT_ID=your_blotato_youtube_account_id
# ============================================================================

# --- Vizard.ai ---
# Get from: Workspace Settings → API
VIZARD_API_KEY=your_vizard_api_key

# --- Telegram Bot ---
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# --- Airtable ---
# PAT: https://airtable.com/create/tokens (scopes: data.records:read, data.records:write)
# Base ID: the "appXXXXXXXXXX" part of your Airtable URL
# Table Name: the name of your clips table
AIRTABLE_PAT=your_airtable_personal_access_token
AIRTABLE_BASE_ID=your_airtable_base_id
AIRTABLE_TABLE_NAME=shortsRobo

# --- Blotato ---
# API Key: Settings → API in the Blotato dashboard
# YouTube Account ID: found in Blotato account settings
BLOTATO_API_KEY=your_blotato_api_key
BLOTATO_YOUTUBE_ACCOUNT_ID=your_blotato_youtube_account_id

# --- Optional (but recommended) ---

# Restrict bot to your Telegram account only
# Without this, ANYONE who finds your bot can use it and burn your Vizard credits!
# How to get it: Send any message to your bot, then check Modal logs for your chat_id
TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- Optional (Vizard customization) ---

# Template ID: controls subtitle style, clip layout, etc.
# Get from: Vizard dashboard → Templates → copy the ID from the URL
# If omitted, Vizard uses its default template
# VIZARD_TEMPLATE_ID=your_template_id

# Language code for subtitle generation (default: en)
# Examples: en, es, fr, de, pt, ja, ko, zh
# VIZARD_LANG=en
