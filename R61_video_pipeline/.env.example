# R61 Video Pipeline — environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# --- Fal.ai (Nano Banana Pro / GPT Image 2 / Gemini TTS) ---
FAL_KEY=

# --- Higgsfield (first/last-frame -> video clip) ---
HIGGSFIELD_API_KEY=
HIGGSFIELD_SECRET=

# --- Cloudflare R2 (raw footage bucket) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# --- Airtable (Video table lives in this base) ---
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# --- Blotato (scheduling only — DO NOT post immediately while hold is in effect) ---
BLOTATO_API_KEY=

# --- Google (Gemini TTS / other Google APIs) ---
GOOGLE_API_KEY=
