# R61 Video Pipeline — Environment Template
#
# Copy to .env and fill in real values. Never commit .env (gitignored).
# See obsidian-brain/clients/Provinzial_Geier_Ayhan/secrets_bootstrap.md
# for retrieval steps, dashboard URLs, and cost implications.

# ──────────────────────────────────────────────────────────────
# Airtable — record source of truth for the Video table
# Dashboard: https://airtable.com/account → Developer hub → Personal access tokens
# Base: appC3HqG42ftswOvw (shared with R57)
# Scope: data.records:read, data.records:write, schema.bases:read
# ──────────────────────────────────────────────────────────────
AIRTABLE_API_KEY=<YOUR_AIRTABLE_API_KEY_HERE>
AIRTABLE_BASE_ID=appC3HqG42ftswOvw

# ──────────────────────────────────────────────────────────────
# ElevenLabs — voiceover TTS
# Dashboard: https://elevenlabs.io/app/settings/api-keys
# Pricing: per-character; budget-tier voice cloning enabled
# ──────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=<YOUR_ELEVENLABS_API_KEY_HERE>

# ──────────────────────────────────────────────────────────────
# Higgsfield — first/last-frame video synthesis (Gate 1 input)
# Dashboard: https://higgsfield.ai/account/api
# Note: requires BOTH key and secret (HMAC-signed requests)
# ──────────────────────────────────────────────────────────────
HIGGSFIELD_API_KEY=<YOUR_HIGGSFIELD_API_KEY_HERE>
HIGGSFIELD_SECRET=<YOUR_HIGGSFIELD_SECRET_HERE>

# ──────────────────────────────────────────────────────────────
# Google — Gemini API (caption polish + script generation)
# Dashboard: https://aistudio.google.com/app/apikey
# ──────────────────────────────────────────────────────────────
GOOGLE_API_KEY=<YOUR_GOOGLE_API_KEY_HERE>

# ──────────────────────────────────────────────────────────────
# Fal.ai — frame gen (nano-banana) + video (kling/sora) + tts (gemini)
# Dashboard: https://fal.ai/dashboard/keys
# Pricing: per-second-of-output (see R57 tools/config.py COSTS table)
# ──────────────────────────────────────────────────────────────
FAL_KEY=<YOUR_FAL_KEY_HERE>

# ──────────────────────────────────────────────────────────────
# Cloudflare R2 — clip + final-render storage (Blotato reads from here)
# Dashboard: https://dash.cloudflare.com/ → R2 → Manage API Tokens
# Bucket: trendiva-raw-assets
# Public URL is the *.r2.dev public-bucket alias (no CDN auth)
# ──────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=<YOUR_R2_ACCOUNT_ID_HERE>
R2_ACCESS_KEY_ID=<YOUR_R2_ACCESS_KEY_ID_HERE>
R2_SECRET_ACCESS_KEY=<YOUR_R2_SECRET_ACCESS_KEY_HERE>
R2_BUCKET_NAME=trendiva-raw-assets
R2_PUBLIC_URL=https://pub-596ca4afabd54a3883ded26dc489279d.r2.dev

# ──────────────────────────────────────────────────────────────
# Blotato — social scheduler (schedule-only; never immediate post)
# Dashboard: https://blotato.com/settings → API keys
# Connected accounts: TikTok, Meta, Instagram (set in UI, not via env)
# ──────────────────────────────────────────────────────────────
BLOTATO_API_KEY=<YOUR_BLOTATO_API_KEY_HERE>

# ──────────────────────────────────────────────────────────────
# R61 feature flags — narrative + caption + B-roll behaviour
# Documented in obsidian-brain/clients/Provinzial_Geier_Ayhan/secrets_bootstrap.md
# ──────────────────────────────────────────────────────────────
R61_ADD_CAPTIONS=1            # 1 = auto-burn captions in hf_stitch; 0 = clean render
R61_BROLL_ENABLED=1           # 1 = inject B-roll/VFX inserts; 0 = single shot only
R61_NARRATIVE_MODE=1          # 1 = use 3-act script structure; 0 = single-prompt
R61_VERSION_TAG=v4            # output-path version namespace (never overwrite prior versions)
